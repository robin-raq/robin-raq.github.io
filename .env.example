# Optional: Formspree or compatible POST endpoint for the contact form
# NEXT_PUBLIC_CONTACT_FORM_ACTION=https://formspree.io/f/xxxxxxxx

# Optional: Google Analytics measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# User site at https://robin-raq.github.io/ — CI sets NEXT_PUBLIC_SITE_URL only (no BASE_PATH).
# If you ever need a project subpath again:
# BASE_PATH=/repo-name
# NEXT_PUBLIC_SITE_URL=https://robin-raq.github.io/repo-name
